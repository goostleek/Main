{
    "version": "2026.4.24",
    "description": "Polyglot tool version manager and task runner",
    "homepage": "https://mise.jdx.dev/",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/jdx/mise/releases/download/v2026.4.24/mise-v2026.4.24-windows-x64.zip",
            "hash": "b8072dca6c8399dbda929db95ff2a1fa261833a2f1dea7e77bc026c8d825d28c"
        },
        "arm64": {
            "url": "https://github.com/jdx/mise/releases/download/v2026.4.24/mise-v2026.4.24-windows-arm64.zip",
            "hash": "4a6ee8e3eb11e3f34842166a4594e6a2cfab4a9df867493415c3d54d663d1782"
        }
    },
    "extract_dir": "mise",
    "bin": "bin/mise.exe",
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\\config.toml\") -and !(Test-Path \"$dir\\config.toml\")) {",
        "    New-Item -Path \"$dir\\config.toml\" -ItemType File -ea 0 | Out-Null",
        "}"
    ],
    "env_set": {
        "MISE_DATA_DIR": "$dir\\mise",
        "MISE_GLOBAL_CONFIG_FILE": "$dir\\config.toml"
    },
    "env_add_path": "mise\\shims",
    "persist": [
        "mise",
        "config.toml"
    ],
    "notes": "See documentation for notes on configuring your shell: https://mise.jdx.dev/installing-mise.html",
    "checkver": {
        "github": "https://github.com/jdx/mise"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/jdx/mise/releases/download/v$version/mise-v$version-windows-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/jdx/mise/releases/download/v$version/mise-v$version-windows-arm64.zip"
            }
        },
        "hash": {
            "url": "$baseurl/SHASUMS256.txt"
        }
    }
}
